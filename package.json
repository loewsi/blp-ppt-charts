{
  "name": "blp-ppt-charts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SlideChart - live-linked chart add-in for PowerPoint (Windows + Mac). v1: stacked column.",
  "scripts": {
    "certs": "office-addin-dev-certs install",
    "gen-icons": "node scripts/gen-icons.mjs",
    "gen-manifest": "node scripts/gen-manifest.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 3000",
    "test": "vitest run",
    "validate": "office-addin-manifest validate manifest.xml"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.377",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@revolist/revogrid": "^4.23.22"
  }
}
